{
  "name": "dispatch-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "electron:dev": "electron electron-main.js",
    "electron:build": "electron-builder --config electron-builder.json",
    "build:desktop": "npm run export:prod && npm run electron:build",
    "export:prod": "cross-env NODE_ENV=production npx expo export",
    "build:web:prod": "cross-env NODE_ENV=production npx expo export -p web",
    "deploy:hosting": "firebase deploy --only hosting",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-picker/picker": "2.11.1",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-env": "^1.1.1",
    "expo-file-system": "~19.0.19",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
