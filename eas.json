        "enterpriseProvisioning": "universal"
      },
      "node": "20.18.0",
      "env": {
        "NODE_ENV": "production"
      },
      "channel": "production"
    },
    "production-custom-app": {
      "distribution": "store",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "node": "20.18.0"
    }
  },
  "submit": {
    "production": {}
  }
