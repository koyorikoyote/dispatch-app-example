      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "node": "20.18.0"
    },
    "production": {
